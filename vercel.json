{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "static/build/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/js/(.*)",
      "dest": "/static/build/static/js/$1"
    },
    {
      "src": "/static/css/(.*)",
      "dest": "/static/build/static/css/$1"
    },
    {
      "src": "/static/media/(.*)",
      "dest": "/static/build/static/media/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
